---
import { profile } from '../data/profile';
---

<section class="hero" id="top">
  <div class="container hero__grid">
    <!-- ── Columna texto ──────────────────────────────────────── -->
    <div class="hero__intro">
      <p class="hero__status mono" data-reveal>
        <span class="hero__status-dot"></span>
        {profile.availability}
      </p>

      <h1 class="hero__name" data-reveal data-reveal-delay="1">
        {profile.name}
      </h1>

      <p class="hero__role mono" data-reveal data-reveal-delay="2">
        <span class="accent">&gt;</span> {profile.role}
        <span class="hero__at">@ {profile.company}</span>
      </p>

      <p class="hero__tagline" data-reveal data-reveal-delay="3">
        {profile.tagline}
      </p>

      <div class="hero__actions" data-reveal data-reveal-delay="4">
        <a href="#projects" class="btn btn--primary">
          Ver proyectos
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14m0 0-6-6m6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#contact" class="btn btn--ghost">Contactar</a>
      </div>

      <ul class="hero__stats" data-reveal data-reveal-delay="4">
        {
          profile.stats.map((s) => (
            <li class="hero__stat">
              <span class="hero__stat-value mono">{s.value}</span>
              <span class="hero__stat-label">{s.label}</span>
            </li>
          ))
        }
      </ul>

      <div class="hero__socials" data-reveal data-reveal-delay="4">
        {
          profile.socials.map((s) => (
            <a href={s.url} target="_blank" rel="noopener noreferrer" class="hero__social mono">
              {s.label.toLowerCase()}<span class="muted">↗</span>
            </a>
          ))
        }
      </div>
    </div>

    <!-- ── Terminal animada ───────────────────────────────────── -->
    <div class="hero__term-wrap" data-reveal data-reveal-delay="2">
      <div class="term" aria-hidden="true" data-parallax="0.05">
        <div class="term__bar">
          <span class="term__dots"><i></i><i></i><i></i></span>
          <span class="term__title mono">~/dev/{profile.initials.toLowerCase()} — zsh</span>
        </div>
        <pre class="term__body mono"><code id="term-out"></code><span class="term__cursor" id="term-cursor">▋</span></pre>
      </div>
      <div class="hero__glow"></div>
    </div>
  </div>

  <a href="#about" class="hero__scroll mono" aria-label="Desplázate hacia abajo">
    scroll <span class="hero__scroll-line"></span>
  </a>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: 6rem 4rem;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  /* ── Intro ───────────────────────────────────────────────────── */
  .hero__status {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.8rem;
    color: var(--accent);
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--accent-dim);
    border-radius: 99px;
    background: var(--accent-glow);
    margin-bottom: 1.6rem;
  }
  .hero__status-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
    animation: blink 1.8s ease-in-out infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .hero__name {
    font-size: clamp(2.6rem, 7vw, 4.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    background: linear-gradient(180deg, #fff 30%, #9fb0c0 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero__role {
    font-size: clamp(1rem, 2.4vw, 1.3rem);
    margin-top: 1rem;
    color: var(--fg);
    font-weight: 500;
  }
  .hero__at { color: var(--fg-faint); }

  .hero__tagline {
    margin-top: 1.4rem;
    color: var(--fg-muted);
    font-size: 1.08rem;
    max-width: 46ch;
  }

  /* ── Botones ─────────────────────────────────────────────────── */
  .hero__actions { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 2rem; }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.4rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: var(--radius-sm);
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s, border-color 0.2s;
  }
  .btn--primary {
    background: var(--accent);
    color: #04130b;
  }
  .btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px -12px var(--accent);
  }
  .btn--primary:hover svg { transform: translateX(3px); }
  .btn--primary svg { transition: transform 0.2s; }
  .btn--ghost {
    border: 1px solid var(--line);
    color: var(--fg);
    background: var(--bg-elev);
  }
  .btn--ghost:hover { border-color: var(--accent-dim); color: var(--accent); transform: translateY(-2px); }

  /* ── Stats ───────────────────────────────────────────────────── */
  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.4rem, 4vw, 2.6rem);
    margin-top: 2.6rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
    list-style: none;
  }
  .hero__stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .hero__stat-value {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }
  .hero__stat-label { font-size: 0.8rem; color: var(--fg-muted); }

  /* ── Socials ─────────────────────────────────────────────────── */
  .hero__socials { display: flex; gap: 1.2rem; margin-top: 1.6rem; }
  .hero__social {
    font-size: 0.85rem;
    color: var(--fg-muted);
    transition: color 0.2s;
  }
  .hero__social:hover { color: var(--accent); }

  /* ── Terminal ────────────────────────────────────────────────── */
  .hero__term-wrap { position: relative; }
  .term {
    position: relative;
    z-index: 2;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, #0c1018, #090c12);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .term__bar {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.7rem 1rem;
    background: var(--bg-elev);
    border-bottom: 1px solid var(--line);
  }
  .term__dots { display: flex; gap: 0.4rem; }
  .term__dots i {
    width: 11px; height: 11px; border-radius: 50%; display: block;
  }
  .term__dots i:nth-child(1) { background: #ff5f57; }
  .term__dots i:nth-child(2) { background: #febc2e; }
  .term__dots i:nth-child(3) { background: #28c840; }
  .term__title { font-size: 0.76rem; color: var(--fg-faint); }

  .term__body {
    padding: 1.3rem 1.4rem;
    font-size: 0.86rem;
    line-height: 1.75;
    min-height: 330px;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .term__cursor {
    color: var(--accent);
    animation: caret 1s step-end infinite;
  }
  @keyframes caret { 50% { opacity: 0; } }

  .hero__glow {
    position: absolute;
    inset: 12% -6% -18% -6%;
    background: radial-gradient(closest-side, var(--accent-glow), transparent 75%);
    filter: blur(20px);
    z-index: 1;
  }

  /* ── Scroll hint ─────────────────────────────────────────────── */
  .hero__scroll {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.72rem;
    color: var(--fg-faint);
    margin-top: 3rem;
    align-self: flex-start;
    margin-inline: var(--gutter);
  }
  .hero__scroll-line {
    width: 40px; height: 1px;
    background: var(--line);
    position: relative;
    overflow: hidden;
  }
  .hero__scroll-line::after {
    content: '';
    position: absolute; inset: 0;
    width: 14px;
    background: var(--accent);
    animation: scrollSlide 2s ease-in-out infinite;
  }
  @keyframes scrollSlide {
    0% { transform: translateX(-14px); }
    100% { transform: translateX(40px); }
  }

  @media (max-width: 900px) {
    .hero__grid { grid-template-columns: 1fr; }
    .hero__term-wrap { order: -1; }
    .term__body { min-height: 240px; }
  }
</style>

<script>
  import { profile } from '../data/profile';

  const out = document.getElementById('term-out');
  const cursor = document.getElementById('term-cursor');
  if (out) {
    const P = '<span style="color:var(--accent)">➜</span> <span style="color:var(--cyan)">~/dev</span> ';
    const lines: { t: string; speed?: number; pause?: number }[] = [
      { t: `${P}whoami\n` },
      { t: `${profile.name.toLowerCase().replace(/\s+/g, '_')}\n\n`, speed: 6 },
      { t: `${P}cat profile.json\n` },
      { t: `{\n`, speed: 4 },
      { t: `  <span style="color:var(--violet)">"role"</span>: <span style="color:var(--accent)">"${profile.role}"</span>,\n`, speed: 4 },
      { t: `  <span style="color:var(--violet)">"company"</span>: <span style="color:var(--accent)">"${profile.company}"</span>,\n`, speed: 4 },
      { t: `  <span style="color:var(--violet)">"stack"</span>: [<span style="color:var(--amber)">"Java"</span>, <span style="color:var(--amber)">"Spring"</span>, <span style="color:var(--amber)">"SQL"</span>],\n`, speed: 4 },
      { t: `  <span style="color:var(--violet)">"learning"</span>: <span style="color:var(--accent)">true</span>\n`, speed: 4 },
      { t: `}\n\n`, speed: 4 },
      { t: `${P}<span class="t-blink">_</span>`, pause: 0 },
    ];

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduce) {
      out.innerHTML = lines.map((l) => l.t).join('');
      cursor?.remove();
    } else {
      let li = 0;
      const type = async () => {
        for (li = 0; li < lines.length; li++) {
          const { t, speed = 22, pause = 260 } = lines[li];
          // escribir respetando tags HTML como unidades
          let i = 0;
          const tokens = tokenize(t);
          await new Promise<void>((resolve) => {
            const step = () => {
              if (i < tokens.length) {
                out.innerHTML += tokens[i++];
                setTimeout(step, speed + Math.random() * 18);
              } else {
                setTimeout(resolve, pause);
              }
            };
            step();
          });
        }
      };
      type();
    }

    // separa el texto en caracteres pero mantiene las etiquetas <...> íntegras
    function tokenize(s: string): string[] {
      const res: string[] = [];
      let i = 0;
      while (i < s.length) {
        if (s[i] === '<') {
          const end = s.indexOf('>', i);
          res.push(s.slice(i, end + 1));
          i = end + 1;
        } else {
          res.push(s[i]);
          i++;
        }
      }
      return res;
    }
  }
</script>
