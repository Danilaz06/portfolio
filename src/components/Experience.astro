---
import { profile } from '../data/profile';
---

<section id="experience" class="exp">
  <div class="container">
    <div class="section-head" data-reveal>
      <span class="section-kicker"><span class="section-index">03</span> / trayectoria</span>
      <h2 class="section-title">Dónde estoy creciendo</h2>
    </div>

    <ol class="timeline">
      {
        profile.experience.map((job, i) => (
          <li class="tl-item" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <span class="tl-node" data-current={job.current ? 'true' : 'false'} />
            <div class="tl-card">
              <div class="tl-head">
                <div>
                  <h3 class="tl-role">{job.role}</h3>
                  <p class="tl-company">
                    {job.company}
                    {job.location && <span class="tl-loc"> · {job.location}</span>}
                  </p>
                </div>
                <span class="tl-period mono">
                  {job.current && <span class="tl-live" />}
                  {job.period}
                </span>
              </div>
              <p class="tl-summary">{job.summary}</p>
              <ul class="tl-highlights">
                {job.highlights.map((h) => (
                  <li><span class="tl-arrow mono">▸</span>{h}</li>
                ))}
              </ul>
              <div class="tl-stack">
                {job.stack.map((t) => <span class="chip">{t}</span>)}
              </div>
            </div>
          </li>
        ))
      }
    </ol>

    {/* Educación */}
    <div class="edu" data-reveal>
      <span class="section-kicker"><span class="section-index">edu</span> / formación</span>
      <div class="edu__grid">
        {
          profile.education.map((e) => (
            <div class="edu__card">
              <h4 class="edu__title">{e.title}</h4>
              <p class="edu__place mono">{e.place}</p>
              <p class="edu__period">{e.period}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .timeline { list-style: none; position: relative; padding-left: 0; }
  .tl-item {
    position: relative;
    padding-left: 2.4rem;
    padding-bottom: 2rem;
  }
  .tl-item::before {
    content: '';
    position: absolute;
    left: 7px; top: 6px; bottom: -6px;
    width: 1px;
    background: linear-gradient(var(--line), transparent);
  }
  .tl-item:last-of-type::before { display: none; }

  .tl-node {
    position: absolute;
    left: 0; top: 6px;
    width: 15px; height: 15px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--line);
  }
  .tl-node[data-current='true'] {
    border-color: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-glow);
  }
  .tl-node[data-current='true']::after {
    content: '';
    position: absolute; inset: 2px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
  }

  .tl-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-soft);
    padding: 1.5rem;
    transition: border-color 0.3s, transform 0.3s;
  }
  .tl-card:hover { border-color: var(--accent-dim); transform: translateX(4px); }

  .tl-head {
    display: flex; justify-content: space-between;
    align-items: flex-start; gap: 1rem; flex-wrap: wrap;
    margin-bottom: 0.9rem;
  }
  .tl-role { font-size: 1.15rem; font-weight: 700; }
  .tl-company { color: var(--accent); font-size: 0.95rem; margin-top: 0.15rem; }
  .tl-loc { color: var(--fg-faint); }
  .tl-period {
    display: inline-flex; align-items: center; gap: 0.45rem;
    font-size: 0.78rem; color: var(--fg-muted);
    border: 1px solid var(--line);
    padding: 0.3rem 0.65rem;
    border-radius: 99px;
    white-space: nowrap;
  }
  .tl-live {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent); box-shadow: 0 0 8px var(--accent);
    animation: blink 1.8s infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .tl-summary { color: var(--fg-muted); margin-bottom: 1rem; }
  .tl-highlights { list-style: none; display: grid; gap: 0.5rem; margin-bottom: 1.2rem; }
  .tl-highlights li {
    display: flex; gap: 0.6rem;
    font-size: 0.92rem; color: var(--fg);
  }
  .tl-arrow { color: var(--accent); flex-shrink: 0; }
  .tl-stack { display: flex; flex-wrap: wrap; gap: 0.45rem; }

  /* ── Educación ───────────────────────────────────────────────── */
  .edu { margin-top: 3rem; }
  .edu .section-kicker { margin-top: 0; }
  .edu__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }
  .edu__card {
    border: 1px solid var(--line);
    border-left: 2px solid var(--accent-dim);
    border-radius: var(--radius-sm);
    padding: 1.2rem 1.4rem;
    background: var(--bg-soft);
  }
  .edu__title { font-size: 1rem; font-weight: 600; }
  .edu__place { font-size: 0.82rem; color: var(--accent); margin-top: 0.3rem; }
  .edu__period { font-size: 0.85rem; color: var(--fg-muted); margin-top: 0.2rem; }
</style>
