---
import { profile } from '../data/profile';

const links = [
  { href: '#about', label: 'whoami', n: '01' },
  { href: '#skills', label: 'stack', n: '02' },
  { href: '#experience', label: 'experience', n: '03' },
  { href: '#projects', label: 'projects', n: '04' },
  { href: '#contact', label: 'contact', n: '05' },
];
---

<header class="nav" id="nav">
  <div class="container nav__inner">
    <a href="#top" class="nav__brand" aria-label="Inicio">
      <span class="nav__dot"></span>
      <span class="mono nav__brand-text">{profile.initials}</span>
      <span class="nav__brand-name">{profile.name}</span>
    </a>

    <nav class="nav__links" aria-label="Navegación principal">
      {
        links.map((l) => (
          <a href={l.href} class="nav__link" data-nav>
            <span class="nav__link-n mono">{l.n}.</span>
            <span class="mono">{l.label}</span>
          </a>
        ))
      }
    </nav>

    <a href={profile.cv} class="nav__cta mono" download>
      <span>cv</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <button class="nav__burger" id="burger" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, background 0.3s;
  }
  .nav.scrolled { border-bottom-color: var(--line); }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 64px;
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 600;
  }
  .nav__dot {
    width: 9px; height: 9px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.55; transform: scale(0.8); }
  }
  .nav__brand-text {
    font-weight: 700;
    color: var(--accent);
    border: 1px solid var(--line);
    padding: 0.1rem 0.4rem;
    border-radius: 6px;
    font-size: 0.85rem;
  }
  .nav__brand-name { font-size: 0.92rem; color: var(--fg); }

  .nav__links { display: flex; align-items: center; gap: 0.35rem; }
  .nav__link {
    position: relative;
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 0.45rem 0.7rem;
    font-size: 0.85rem;
    color: var(--fg-muted);
    border-radius: var(--radius-sm);
    transition: color 0.2s, background 0.2s;
  }
  .nav__link:hover { color: var(--fg); background: var(--bg-elev); }
  .nav__link.active { color: var(--accent); }
  .nav__link-n { color: var(--accent); font-size: 0.72rem; }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.9rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    border: 1px solid var(--accent-dim);
    border-radius: var(--radius-sm);
    background: var(--accent-glow);
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .nav__cta:hover {
    background: var(--accent);
    color: #04130b;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px -8px var(--accent);
  }

  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 38px; height: 38px;
    align-items: center; justify-content: center;
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
  }
  .nav__burger span {
    width: 18px; height: 2px;
    background: var(--fg);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }
  .nav.open .nav__burger span:nth-child(1) { transform: translateY(3.5px) rotate(45deg); }
  .nav.open .nav__burger span:nth-child(2) { transform: translateY(-3.5px) rotate(-45deg); }

  @media (max-width: 860px) {
    .nav__cta { display: none; }
    .nav__burger { display: flex; }
    .nav__links {
      position: absolute;
      top: 64px; left: 0; right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.6rem var(--gutter) 1.2rem;
      background: var(--bg-soft);
      border-bottom: 1px solid var(--line);
      transform: translateY(-12px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s, transform 0.25s;
    }
    .nav.open .nav__links { opacity: 1; transform: none; pointer-events: auto; }
    .nav__link { padding: 0.85rem 0.4rem; font-size: 1rem; }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  const burger = document.getElementById('burger');

  // sombra/borde al hacer scroll
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 12);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // menú móvil
  burger?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(open));
  });
  document.querySelectorAll('[data-nav]').forEach((a) =>
    a.addEventListener('click', () => nav?.classList.remove('open'))
  );

  // sección activa
  const navLinks = [...document.querySelectorAll('[data-nav]')];
  const spy = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          const id = '#' + e.target.id;
          navLinks.forEach((l) =>
            l.classList.toggle('active', l.getAttribute('href') === id)
          );
        }
      }
    },
    { rootMargin: '-45% 0px -50% 0px' }
  );
  ['about', 'skills', 'experience', 'projects', 'contact'].forEach((id) => {
    const el = document.getElementById(id);
    if (el) spy.observe(el);
  });
</script>
